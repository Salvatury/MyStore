@model List<CategoriaVM>

<div class="row justify-content-between mt-4">
    <div class="col-4">
        <h4>Categorias</h4>
    </div>
    <div class="col-4 text-end">
        <a href="/Categoria/AgregarEditar" class="btn btn-success"><i class="fa-solid fa-plus"></i></a>
    </div>
</div>
<hr />
<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th style="width:120px">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td style="width:120px">
                    <a href="/Categoria/AgregarEditar/@item.CategoriaId" class="btn btn-sm btn-primary"><i class="fa-solid fa-pen"></i></a>
                    <button class="btn btn-sm btn-danger" onclick="eliminarItem(@item.CategoriaId)"><i class="fa-solid fa-trash-can"></i></button>
                </td>
            </tr>
        }
    </tbody>
</table>
<script>
    function eliminarItem(id){
        if(confirm("Los datos se borraran, desea continuar?")){
            window.location.href= '@Url.Action("Eliminar", "Categoria")/'+id;
        }
    }


</script>


